# .env.example

# Your Google Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Your n8n webhook URL for lead forwarding
N8N_WEBHOOK_URL="https://api.plumblead.ai/webhook/plumblead-quote"

# Optional: Override the AI model used for generating quotes (e.g., gemini-pro)
# PLUMBLEAD_QUOTE_AI_MODEL="gemini-pro"

# OpenClaw Integration
OPENCLAW_API_ENDPOINT="your_openclaw_api_endpoint_here" # e.g., http://<your_ip>:18789/api/message
OPENCLAW_API_KEY="your_openclaw_api_key_here"
