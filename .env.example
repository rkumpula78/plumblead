# .env.example

# ── Required ──────────────────────────────────────────────────────────────────

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY="your_gemini_api_key_here"

# n8n webhook URL for lead routing
N8N_WEBHOOK_URL="https://your-n8n-domain/webhook/plumblead-quote"

# Port (Railway sets this automatically — only needed for local dev)
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────

# Postgres connection string (Railway injects this automatically)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Dashboard Auth ────────────────────────────────────────────────────────────

# Admin key for /api/leads and /api/contractors endpoints
DASHBOARD_ADMIN_KEY="plumblead-admin-2026"

# ── Optional ──────────────────────────────────────────────────────────────────

# Override the Gemini model used for quotes and chat
# Default is gemini-2.0-flash — only change if you want to test another model
# PLUMBLEAD_QUOTE_AI_MODEL="gemini-2.0-flash"
