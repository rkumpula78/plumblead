      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [900, 400]
    },
    {
      "parameters": {
        "sendTo": "rkumpula@gmail.com",
        "subject": "={{ '⚡ New Lead: ' + $('Webhook — Receive Lead').first().json.body.serviceType + ' — ' + $('Webhook — Receive Lead').first().json.body.location }}",
        "emailType": "html",
        "message": "={{ '<h2>New Homeowner Lead</h2><table style=\"border-collapse:collapse;width:100%;font-family:sans-serif\"><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Name</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.name + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Phone</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.phone + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Email</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.email + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Service</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.serviceType + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Details</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.details + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Location</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.location + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Estimate Range</td><td style=\"padding:8px;border:1px solid #ddd\"><strong>' + $('Webhook — Receive Lead').first().json.body.estimateRange + '</strong></td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Lead Score</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.leadScore + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Cross-Sell</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.crossSellOpportunities + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Timestamp</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.timestamp + '</td></tr></table>' }}",
        "options": {}
      },
      "id": "email-ryan-lead",
      "name": "Email Ryan — New Lead Alert",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [900, 520]
    },
    {
      "parameters": {
        "amount": 2,
        "unit": "hours"
      },
