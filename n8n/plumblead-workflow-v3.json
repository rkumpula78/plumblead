    },
    "Respond — Lead ACK": {
      "main": [[{ "node": "SMS Homeowner — 60s Response", "type": "main", "index": 0 }]]
    },
    "SMS Homeowner — 60s Response": {
      "main": [[{ "node": "Email Ryan — New Lead Alert", "type": "main", "index": 0 }]]
