        "message": "={{ '<h2>New PlumbLead.ai Trial Signup</h2><table style=\"border-collapse:collapse;width:100%;font-family:sans-serif\"><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Name</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.firstName + ' ' + $('Webhook — Receive Lead').first().json.body.lastName + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Company</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.company + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Phone</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.phone + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Email</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.email + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Trucks</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.trucks + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">CRM</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.crm + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">City</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.city + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">How They Heard</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.hearAbout + '</td></tr><tr><td style=\"padding:8px;border:1px solid #ddd;font-weight:bold\">Submitted At</td><td style=\"padding:8px;border:1px solid #ddd\">' + $('Webhook — Receive Lead').first().json.body.submittedAt + '</td></tr></table><br><p><a href=\"https://plumblead.ai/dashboard\">View Dashboard</a></p>' }}",
        "options": {}
      },
      "id": "email-ryan-trial",
      "name": "Email Ryan — New Trial",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [900, 80]
    },
    {
      "parameters": {
        "operation": "send",
        "from": "+18335580877",
        "to": "={{ $('Webhook — Receive Lead').first().json.body.phone }}",
        "message": "={{ 'Hey ' + $('Webhook — Receive Lead').first().json.body.firstName + \", you're in! Your PlumbLead.ai 14-day free trial for \" + $('Webhook — Receive Lead').first().json.body.company + ' is being set up now. You\\'ll receive your login and setup guide at ' + $('Webhook — Receive Lead').first().json.body.email + ' within 2 hours. Questions? Call or text (833) 558-0877. Reply STOP to opt out.' }}",
        "options": {}
      },
      "id": "sms-plumber-trial",
      "name": "SMS Plumber — Trial Confirmation",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [900, 200]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"status\": \"received\", \"type\": \"homeowner_lead\" }",
        "options": {}
