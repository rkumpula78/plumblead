      "name": "Wait 2 Hours",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "operation": "send",
        "from": "+18335580877",
        "to": "={{ $('Webhook — Receive Lead').first().json.body.phone }}",
        "message": "={{ 'Hi ' + $('Webhook — Receive Lead').first().json.body.name + ', just checking in on your ' + $('Webhook — Receive Lead').first().json.body.serviceType + \" request. Have you been connected with a plumber yet? Reply YES if you're all set, or call (833) 558-0877 and we'll get you taken care of right away. Reply STOP to opt out.\" }}",
        "options": {}
      },
      "id": "sms-followup-2hr",
      "name": "SMS Homeowner — 2hr Follow-Up",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [1340, 400]
    }
  ],
  "connections": {
    "Webhook — Receive Lead": {
      "main": [[{ "node": "IF — Trial Signup or Homeowner Lead?", "type": "main", "index": 0 }]]
